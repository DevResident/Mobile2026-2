<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/nothing_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_nothing_panel"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp">

        <TextView
            android:id="@+id/tvStep"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans"
            android:text="Paso: 0"
            android:textAllCaps="true"
            android:textColor="@color/nothing_text"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:gravity="center"/>

        <TextView
            android:id="@+id/tvCollisions"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Colisiones: 0"
            android:textAllCaps="true"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:textColor="@color/nothing_red"
            android:gravity="center"/>
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_airspace_panel"
        android:padding="10dp">

        <com.example.clase13.AirspaceView
            android:id="@+id/airspaceView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="12dp">

        <Button
            android:id="@+id/btnPrev"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_nothing_button"
            android:fontFamily="sans"
            android:minHeight="48dp"
            android:paddingHorizontal="12dp"
            android:text="Paso anterior"
            android:textAllCaps="true"
            android:textColor="@color/nothing_button_text"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:enabled="false"/>

        <Button
            android:id="@+id/btnNext"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_nothing_button"
            android:fontFamily="sans"
            android:minHeight="48dp"
            android:paddingHorizontal="12dp"
            android:textAllCaps="true"
            android:textColor="@color/nothing_button_text"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:text="Paso siguiente"/>
    </LinearLayout>

</LinearLayout>
